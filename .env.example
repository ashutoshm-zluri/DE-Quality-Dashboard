# Copy to .env (gitignored) for local dev.
# Render uses its own dashboard env vars — same keys, different values.

# ── Storage backend ─────────────────────────────────────────────────────────
# "local"  → write under FAILING_FLOWS_DIR (good for offline dev)
# "s3"     → write to s3://${S3_BUCKET}/${S3_PREFIX}<env>/<key>  (production)
STORAGE_BACKEND=local
FAILING_FLOWS_DIR=/Users/ashutosh/ZluriHQ/failing-flows

S3_BUCKET=de-quality-dashboard
S3_REGION=us-east-1
S3_PREFIX=

# AWS credentials. Pick ONE:
#   - AWS_PROFILE for SSO (refresh with `aws sso login` when expired)
#   - or the three AWS_* vars below (long-lived IAM user keys; used on Render)
AWS_PROFILE=DE-team-Interns-permissions-637188757652
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ── App ─────────────────────────────────────────────────────────────────────
API_PORT=5174

# 32-byte random hex used to sign session JWTs:  openssl rand -hex 32
SESSION_SECRET=

# 32-byte random hex used by GitHub Actions cron to authenticate against
# /api/internal/refresh.  Same value goes in repo secrets.
INTERNAL_CRON_TOKEN=

# Block /trigger, /mark-complete, /rerun-all in prod until platform grants
# mongo prod write credentials. Keep false until you have them.
PROD_WRITES_ENABLED=false

# ── Mongo ───────────────────────────────────────────────────────────────────
# Used by the Node recovery package (server/recovery/*) for discovery and
# (eventually) for mark-complete writes.
MONGO_URI_DEV=
MONGO_URI_PROD=

DISCOVERY_WINDOW_DAYS=30
STALENESS_HOURS=48

# Comma-separated orgIntegrationIds. When --dev-safe is passed, discover
# limits queries to this allowlist.
DEV_SAFE_ALLOWLIST=

# ── Google OAuth ────────────────────────────────────────────────────────────
# Same value in both lines. Vite only exposes VITE_-prefixed vars to the client.
# Authorized JS origins:
#   http://localhost:5173  (dev)
#   https://<your-vercel-app>.vercel.app  (prod)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Optional: restrict sign-in to one Google Workspace domain. Leave blank for any.
ALLOWED_EMAIL_DOMAIN=zluri.com

# ── Jira (Release Tracker → Sync from Jira) ─────────────────────────────────
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://zluri.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
